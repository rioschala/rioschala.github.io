---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content"; 
import BlogHero from "@/components/blog/Hero.astro";
import TOC from "@/components/blog/TOC.astro";
import Giscus from "@/components/Giscus.astro";
import { getBacklinks } from "@/data/post";

import BaseLayout from "./Base.astro";

import 'katex/dist/katex.min.css';

interface Props {
    post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const {
    data: { description, ogImage, publishDate, title, updatedDate },
    id, // In Astro 6, use 'id' instead of 'slug'
} = post;

// Update socialImage to use id
const socialImage = ogImage ?? `/og-image/${id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();

// FIX: Use the standalone render function
const { headings } = await render(post);
const backlinks = await getBacklinks(id);
---

<BaseLayout meta={{ articleDate, description, ogImage: socialImage, title }}>
	<div class="gap-x-10 lg:flex lg:items-start">
		{!!headings.length && <TOC headings={headings} />}
		<article class="flex-grow break-words" data-pagefind-body>
			<div id="blog-hero"><BlogHero content={post} /></div>
			<div
				class="prose prose-sm prose-cactus mt-12 prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-accent prose-headings:before:content-['#'] prose-th:before:content-none"
			>
				<slot />
			</div>

			{backlinks.length > 0 && (
				<div class="mt-8 pt-8 border-t border-zinc-200 dark:border-zinc-700">
					<h2 class="text-lg font-semibold text-accent-2 mb-4">Linked Mentions</h2>
					<ul class="space-y-4">
						{backlinks.map((b) => (
							<li class="flex flex-col">
								<a href={`/posts/${b.id}/`} class="text-accent hover:underline decoration-dashed decoration-2 underline-offset-4">
									{b.data.title}
								</a>
								{b.data.description && <span class="text-sm text-gray-500 dark:text-gray-400">{b.data.description}</span>}
							</li>
						))}
					</ul>
				</div>
			)}

			<Giscus />
		</article>
	</div>
	<button
		aria-label="Back to Top"
		class="z-90 fixed bottom-8 end-4 flex h-10 w-10 translate-y-28 items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all duration-300 hover:border-zinc-400 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 dark:bg-zinc-700 sm:end-8 sm:h-12 sm:w-12"
		data-show="false"
		id="to-top-btn"
		><svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<script>
    function setupPageFeatures() {
        /** --- BACK TO TOP LOGIC --- **/
        const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
        const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

        if (scrollBtn && targetHeader) {
            const callback = (entries: IntersectionObserverEntry[]) => {
                entries.forEach((entry) => {
                    scrollBtn.dataset.show = (!entry.isIntersecting).toString();
                });
            };

            scrollBtn.addEventListener("click", () => {
                document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
            });

            const observer = new IntersectionObserver(callback);
            observer.observe(targetHeader);
        }

        /** --- FOOTNOTE PREVIEW LOGIC --- **/
        // Selects footnote links (handles both standard Markdown and MDX prefixes)
        const footnoteLinks = document.querySelectorAll('a[href^="#fn-"], a[id^="user-content-fnref-"], a[data-footnote-ref]');

        footnoteLinks.forEach((link) => {
            const anchor = link as HTMLAnchorElement;
            const id = decodeURIComponent(anchor.hash.substring(1));
            const footnoteContent = document.getElementById(id);

            if (footnoteContent) {
                // Create the tooltip container
                const tooltip = document.createElement("div");
                // Tailwind classes for styling
                tooltip.className = "footnote-tooltip hidden absolute z-50 max-w-sm p-3 bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-lg shadow-xl text-sm leading-normal opacity-0 transition-opacity duration-200 pointer-events-none";
                
                // Clone the footnote content and remove the "back to text" arrow
                const contentClone = footnoteContent.cloneNode(true) as HTMLElement;
                const backRef = contentClone.querySelector('.footnote-backref, [data-footnote-backref]');
                if (backRef) backRef.remove();
                
                tooltip.innerHTML = contentClone.innerHTML;
                document.body.appendChild(tooltip);

                const showTooltip = () => {
                    const rect = anchor.getBoundingClientRect();
                    tooltip.classList.remove("hidden");
                    
                    // Positioning the tooltip above the number
                    const tooltipWidth = tooltip.offsetWidth;
                    const tooltipHeight = tooltip.offsetHeight;
                    
                    const left = rect.left + window.scrollX - (tooltipWidth / 2) + (rect.width / 2);
                    const top = rect.top + window.scrollY - tooltipHeight - 12;

                    tooltip.style.left = `${left}px`;
                    tooltip.style.top = `${top}px`;
                    
                    // Simple fade in
                    requestAnimationFrame(() => {
                        tooltip.classList.add("opacity-100");
                    });
                };

                const hideTooltip = () => {
                    tooltip.classList.remove("opacity-100");
                    // Wait for transition before hiding
                    setTimeout(() => {
                        if (tooltip.classList.contains("opacity-0")) {
                            tooltip.classList.add("hidden");
                        }
                    }, 200);
                };

                anchor.addEventListener("mouseenter", showTooltip);
                anchor.addEventListener("mouseleave", hideTooltip);
            }
        });
    }

    // Initialize on first load
    setupPageFeatures();

    // Re-initialize if using Astro View Transitions
    document.addEventListener("astro:after-swap", setupPageFeatures);
</script>

<style is:global>
    .footnote-tooltip {
        @apply pointer-events-none absolute z-50 max-w-sm rounded-lg border border-zinc-300 bg-white p-3 shadow-xl transition-opacity duration-200 dark:border-zinc-600 dark:bg-zinc-800 text-sm leading-relaxed;
    }

    /* Small arrow pointing down */
    .footnote-tooltip::after {
        content: "";
        @apply absolute top-full left-1/2 -ml-2 border-[8px] border-transparent border-t-white dark:border-t-zinc-800;
    }
    
    /* Border for the arrow to match tooltip border */
    .footnote-tooltip::before {
        content: "";
        @apply absolute top-full left-1/2 -ml-[9px] border-[9px] border-transparent border-t-zinc-300 dark:border-t-zinc-600;
    }
</style>